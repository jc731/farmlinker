---
import '@/styles/globals.css';
import DevToolbar from '@/components/DevToolbar.astro';

interface Props {
  title: string;
}

const { title } = Astro.props;
const { profile } = Astro.locals;
const pathname = new URL(Astro.request.url).pathname;

const navItems = [
  { href: '/admin', label: 'Dashboard' },
  { href: '/admin/review/users', label: 'Pending users' },
  { href: '/admin/users', label: 'All users' },
  { href: '/admin/review/listings', label: 'Pending listings' },
  { href: '/admin/inquiries', label: 'Inquiries' },
];
---

<!doctype html>
<html lang="en">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <link rel="icon" type="image/svg+xml" href="/favicon.svg" />
    <title>{title} — Admin | Farmlinker</title>
  </head>
  <body class="min-h-screen bg-muted/30">
    <header class="border-b bg-zinc-900 text-white">
      <div class="mx-auto flex h-12 max-w-6xl items-center justify-between px-4">
        <div class="flex items-center gap-4">
          <a href="/admin" class="font-bold tracking-tight">Farmlinker Admin</a>
          <span class="text-zinc-500">|</span>
          <nav class="flex items-center gap-1">
            {navItems.map(({ href, label }) => (
              <a
                href={href}
                class:list={[
                  'rounded px-3 py-1.5 text-sm transition-colors',
                  pathname === href || (href !== '/admin' && pathname.startsWith(href))
                    ? 'bg-white/10 text-white'
                    : 'text-zinc-400 hover:text-white',
                ]}
              >
                {label}
              </a>
            ))}
          </nav>
        </div>
        <div class="flex items-center gap-3 text-sm text-zinc-400">
          <span>{profile?.first_name} {profile?.last_name}</span>
          <a href="/app" class="hover:text-white">← App</a>
        </div>
      </div>
    </header>
    <main class="mx-auto max-w-6xl px-4 py-8">
      <slot />
    </main>
    {import.meta.env.DEV && <DevToolbar />}
  </body>
</html>
