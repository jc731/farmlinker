---
import AppLayout from '@/layouts/AppLayout.astro';
import { LandownerProfileForm } from '@/components/onboarding/LandownerProfileForm';

const { profile } = Astro.locals;

if (!profile?.roles.includes('landowner')) {
  return Astro.redirect('/app');
}
---

<AppLayout title="Landowner Profile">
  <div class="mx-auto max-w-2xl space-y-6">
    <div>
      <h1 class="text-2xl font-bold">Complete your landowner profile</h1>
      <p class="text-muted-foreground">
        Just a couple of quick questions before you get started. Once your profile
        is reviewed, you'll be able to create a listing for your land.
      </p>
    </div>
    <LandownerProfileForm client:load />
  </div>
</AppLayout>
