---
import AppLayout from '@/layouts/AppLayout.astro';
import { FarmerProfileForm } from '@/components/onboarding/FarmerProfileForm';

const { profile } = Astro.locals;

if (!profile?.roles.includes('farmer')) {
  return Astro.redirect('/app');
}
---

<AppLayout title="Farmer Profile">
  <div class="mx-auto max-w-2xl space-y-6">
    <div>
      <h1 class="text-2xl font-bold">Complete your farmer profile</h1>
      <p class="text-muted-foreground">
        Tell us about your farming goals and what you're looking for in land.
        This helps us match you with the right landowners.
      </p>
    </div>
    <FarmerProfileForm client:load />
  </div>
</AppLayout>
