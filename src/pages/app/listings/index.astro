---
import AppLayout from '@/layouts/AppLayout.astro';
import DataTable from '@/components/DataTable.astro';
import Th from '@/components/Th.astro';
import Tr from '@/components/Tr.astro';
import Td from '@/components/Td.astro';
import EmptyState from '@/components/EmptyState.astro';
import PageHeader from '@/components/PageHeader.astro';
import { fmtDate } from '@/lib/format';

const { supabase, profile } = Astro.locals;

if (!profile?.roles.includes('landowner')) {
  return Astro.redirect('/app');
}

const { data: listings } = await supabase
  .from('listings')
  .select('id, property_name, county, total_acreage, farmable_acreage, status, created_at')
  .eq('owner_profile_id', profile.id)
  .order('created_at', { ascending: false });

const active   = (listings ?? []).filter(l => l.status !== 'archived');
const archived = (listings ?? []).filter(l => l.status === 'archived');

const STATUS_COLORS: Record<string, string> = {
  draft:    'bg-zinc-100 text-zinc-600',
  pending:  'bg-amber-100 text-amber-700',
  approved: 'bg-green-100 text-green-700',
  rejected: 'bg-red-100 text-red-700',
  archived: 'bg-zinc-100 text-zinc-500',
};

---

<AppLayout title="My listings">
  <div class="space-y-6">
    <PageHeader title="My listings">
      <a
        slot="action"
        href="/app/listings/new"
        class="rounded-md bg-primary px-4 py-2 text-sm font-medium text-primary-foreground hover:bg-primary/90"
      >
        + New listing
      </a>
    </PageHeader>

    {active.length === 0 ? (
      <EmptyState message="No listings yet.">
        <a
          href="/app/listings/new"
          class="mt-4 inline-block rounded-md bg-primary px-4 py-2 text-sm font-medium text-primary-foreground hover:bg-primary/90"
        >
          Create your first listing
        </a>
      </EmptyState>
    ) : (
      <DataTable>
        <tr slot="head">
          <Th>Property</Th>
          <Th>County</Th>
          <Th>Acreage</Th>
          <Th>Status</Th>
          <Th>Created</Th>
          <Th></Th>
        </tr>
        {active.map(l => (
          <Tr>
            <Td class="font-medium">
              {l.property_name ?? <span class="text-muted-foreground italic">Unnamed</span>}
            </Td>
            <Td class="text-muted-foreground">{l.county ?? '—'}</Td>
            <Td class="text-muted-foreground">
              {l.farmable_acreage != null ? `${l.farmable_acreage} ac farmable` : l.total_acreage != null ? `${l.total_acreage} ac total` : '—'}
            </Td>
            <Td>
              <span class:list={['rounded-full px-2 py-0.5 text-xs font-medium capitalize', STATUS_COLORS[l.status] ?? 'bg-muted text-muted-foreground']}>
                {l.status}
              </span>
            </Td>
            <Td class="text-muted-foreground">{fmtDate(l.created_at)}</Td>
            <Td>
              <a href={`/app/listings/${l.id}`} class="text-xs text-primary hover:underline">View →</a>
            </Td>
          </Tr>
        ))}
      </DataTable>
    )}

    {archived.length > 0 && (
      <details class="group">
        <summary class="flex cursor-pointer items-center gap-2 text-sm font-medium text-muted-foreground hover:text-foreground">
          <svg xmlns="http://www.w3.org/2000/svg" width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" class="transition-transform group-open:rotate-90" aria-hidden="true"><path d="m9 18 6-6-6-6"/></svg>
          Archived listings ({archived.length})
        </summary>
        <div class="mt-3">
          <DataTable>
            <tr slot="head">
              <Th>Property</Th>
              <Th>County</Th>
              <Th>Acreage</Th>
              <Th>Created</Th>
              <Th></Th>
            </tr>
            {archived.map(l => (
              <Tr class="opacity-60">
                <Td class="font-medium">
                  {l.property_name ?? <span class="italic text-muted-foreground">Unnamed</span>}
                </Td>
                <Td class="text-muted-foreground">{l.county ?? '—'}</Td>
                <Td class="text-muted-foreground">
                  {l.farmable_acreage != null ? `${l.farmable_acreage} ac farmable` : l.total_acreage != null ? `${l.total_acreage} ac total` : '—'}
                </Td>
                <Td class="text-muted-foreground">{fmtDate(l.created_at)}</Td>
                <Td>
                  <a href={`/app/listings/${l.id}`} class="text-xs text-primary hover:underline">View →</a>
                </Td>
              </Tr>
            ))}
          </DataTable>
        </div>
      </details>
    )}
  </div>
</AppLayout>
