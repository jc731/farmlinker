---
import AppLayout from '@/layouts/AppLayout.astro';
import { Card, CardContent, CardHeader, CardTitle, CardDescription } from '@/components/ui/card';

const { profile } = Astro.locals;
const isPending  = profile?.status === 'pending';
const isApproved = profile?.status === 'approved';
const isRejected = profile?.status === 'rejected';
const isFarmer   = profile?.roles.includes('farmer');
const isLandowner = profile?.roles.includes('landowner');
---

<AppLayout title="Dashboard">
  <div class="space-y-6">
    <div>
      <h1 class="text-2xl font-bold">
        Welcome{profile?.first_name ? `, ${profile.first_name}` : ''}
      </h1>
      <p class="text-muted-foreground">
        <span class="capitalize">{profile?.roles.join(' & ')}</span>
        {isPending && <span class="ml-1">· Pending review</span>}
        {isApproved && <span class="ml-1">· Approved</span>}
      </p>
    </div>

    {isRejected && (
      <Card>
        <CardHeader>
          <CardTitle>Application not approved</CardTitle>
          <CardDescription>
            Your application was not approved at this time. If you have questions,
            please contact us at <a href="mailto:hello@farmlinker.com" class="text-primary hover:underline">hello@farmlinker.com</a>.
          </CardDescription>
        </CardHeader>
      </Card>
    )}

    {isPending && (
      <Card>
        <CardHeader>
          <CardTitle>Application under review</CardTitle>
          <CardDescription>
            Your profile has been submitted and is awaiting admin review. You'll receive
            access to {isFarmer ? 'contact landowners' : 'receive farmer inquiries'} once approved.
          </CardDescription>
        </CardHeader>
      </Card>
    )}

    {isApproved && (
      <div class="grid gap-4 sm:grid-cols-2 lg:grid-cols-3">
        {isFarmer && (
          <Card>
            <CardHeader>
              <CardTitle className="text-base">Browse listings</CardTitle>
              <CardDescription>Find available farmland in your area.</CardDescription>
            </CardHeader>
            <CardContent>
              <a
                href="/app/browse"
                class="inline-flex w-full items-center justify-center rounded-md border border-input bg-background px-4 py-2 text-sm font-medium hover:bg-accent"
              >
                Browse farmland
              </a>
            </CardContent>
          </Card>
        )}
        {isLandowner && (
          <Card>
            <CardHeader>
              <CardTitle className="text-base">My listings</CardTitle>
              <CardDescription>Manage your land listings.</CardDescription>
            </CardHeader>
            <CardContent>
              <a
                href="/app/listings"
                class="inline-flex w-full items-center justify-center rounded-md border border-input bg-background px-4 py-2 text-sm font-medium hover:bg-accent"
              >
                View listings
              </a>
            </CardContent>
          </Card>
        )}
        <Card>
          <CardHeader>
            <CardTitle className="text-base">Inquiries</CardTitle>
            <CardDescription>Your active conversations.</CardDescription>
          </CardHeader>
          <CardContent>
            <a
              href="/app/inquiries"
              class="inline-flex w-full items-center justify-center rounded-md border border-input bg-background px-4 py-2 text-sm font-medium hover:bg-accent"
            >
              View inquiries
            </a>
          </CardContent>
        </Card>
      </div>
    )}
  </div>
</AppLayout>
