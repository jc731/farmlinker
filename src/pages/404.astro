---
import '@/styles/globals.css';

// Profile may or may not be available depending on where the 404 occurred
const profile = Astro.locals.profile ?? null;
const isSignedIn = !!profile;
---

<!doctype html>
<html lang="en">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <link rel="icon" type="image/svg+xml" href="/favicon.svg" />
    <title>Page not found | Farmlinker</title>
  </head>
  <body class="min-h-screen bg-background font-sans text-foreground">

    <!-- Minimal nav -->
    <header class="border-b bg-white">
      <div class="mx-auto flex h-14 max-w-5xl items-center justify-between px-4">
        <a href="/" class="text-lg font-bold text-primary">Farmlinker</a>
        <div class="flex items-center gap-2 text-sm">
          {isSignedIn ? (
            <a href="/app" class="rounded-md bg-primary px-4 py-1.5 font-medium text-primary-foreground hover:bg-primary/90">
              Go to app
            </a>
          ) : (
            <>
              <a href="/auth/sign-in" class="px-3 py-1.5 text-muted-foreground hover:text-foreground">Sign in</a>
              <a href="/auth/sign-up" class="rounded-md bg-primary px-4 py-1.5 font-medium text-primary-foreground hover:bg-primary/90">
                Create account
              </a>
            </>
          )}
        </div>
      </div>
    </header>

    <main class="flex min-h-[calc(100vh-57px)] flex-col items-center justify-center px-4 py-16 text-center">
      <!-- Illustration -->
      <div class="mb-8 flex h-40 w-40 items-center justify-center rounded-full bg-gradient-to-br from-primary/10 to-primary/5">
        <svg viewBox="0 0 80 55" xmlns="http://www.w3.org/2000/svg" class="h-20 w-20 text-primary/30" aria-hidden="true">
          <circle cx="62" cy="14" r="9" fill="currentColor" opacity="0.5"/>
          <ellipse cx="80" cy="50" rx="55" ry="22" fill="currentColor" opacity="0.25"/>
          <ellipse cx="20" cy="55" rx="40" ry="18" fill="currentColor" opacity="0.4"/>
          <line x1="35" y1="42" x2="35" y2="26" stroke="currentColor" stroke-width="1.5" opacity="0.5"/>
          <ellipse cx="35" cy="23" rx="3" ry="7" fill="currentColor" opacity="0.45"/>
          <line x1="44" y1="44" x2="44" y2="30" stroke="currentColor" stroke-width="1.5" opacity="0.5"/>
          <ellipse cx="44" cy="27" rx="3" ry="7" fill="currentColor" opacity="0.45"/>
          <line x1="26" y1="45" x2="26" y2="32" stroke="currentColor" stroke-width="1.5" opacity="0.5"/>
          <ellipse cx="26" cy="29" rx="3" ry="6" fill="currentColor" opacity="0.45"/>
        </svg>
      </div>

      <div class="text-6xl font-bold text-primary/20">404</div>
      <h1 class="mt-2 text-2xl font-bold">Page not found</h1>
      <p class="mt-3 max-w-md text-muted-foreground">
        This page doesn't exist or may have been moved. Let's get you back to familiar ground.
      </p>

      <!-- Navigation options -->
      <div class="mt-8 flex flex-col items-center gap-3 sm:flex-row">
        <a href="/"
          class="w-full rounded-md bg-primary px-5 py-2.5 text-sm font-medium text-primary-foreground hover:bg-primary/90 sm:w-auto">
          Go home
        </a>
        {isSignedIn ? (
          <>
            <a href="/app"
              class="w-full rounded-md border px-5 py-2.5 text-sm font-medium hover:bg-muted sm:w-auto">
              Dashboard
            </a>
            <a href="/app/browse"
              class="w-full rounded-md border px-5 py-2.5 text-sm font-medium hover:bg-muted sm:w-auto">
              Browse listings
            </a>
          </>
        ) : (
          <a href="/auth/sign-in"
            class="w-full rounded-md border px-5 py-2.5 text-sm font-medium hover:bg-muted sm:w-auto">
            Sign in
          </a>
        )}
      </div>
    </main>

  </body>
</html>
