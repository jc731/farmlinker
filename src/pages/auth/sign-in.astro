---
import AuthLayout from '@/layouts/AuthLayout.astro';
import { Card, CardContent, CardHeader, CardTitle, CardDescription } from '@/components/ui/card';
import { SignInForm } from '@/components/auth/SignInForm';

const { profile } = Astro.locals;
if (profile) return Astro.redirect('/app');

const errorParam = Astro.url.searchParams.get('error');
// Validate next to prevent open redirect — must be a relative path
const rawNext = Astro.url.searchParams.get('next') ?? '';
const nextParam = rawNext.startsWith('/') && !rawNext.startsWith('//') ? rawNext : '';
---

<AuthLayout title="Sign in">
  <Card>
    <CardHeader>
      <CardTitle>Welcome back</CardTitle>
      <CardDescription>Sign in to your Farmlinker account.</CardDescription>
    </CardHeader>
    <CardContent>
      <SignInForm client:load errorParam={errorParam} next={nextParam} />
    </CardContent>
  </Card>
</AuthLayout>
