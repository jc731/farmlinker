---
import BaseLayout from '@/layouts/BaseLayout.astro';

const { user } = Astro.locals;

const CHECK = `<svg class="h-4 w-4 shrink-0 text-primary mt-0.5" fill="currentColor" viewBox="0 0 20 20"><path fill-rule="evenodd" d="M16.704 4.153a.75.75 0 0 1 .143 1.052l-8 10.5a.75.75 0 0 1-1.127.075l-4.5-4.5a.75.75 0 0 1 1.06-1.06l3.894 3.893 7.48-9.817a.75.75 0 0 1 1.05-.143Z" clip-rule="evenodd"/></svg>`;

const features = [
  {
    icon: `<svg class="h-6 w-6" fill="none" stroke="currentColor" stroke-width="1.5" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" d="M9 12.75 11.25 15 15 9.75M21 12a9 9 0 1 1-18 0 9 9 0 0 1 18 0Z"/></svg>`,
    title: 'Vetted network',
    body: 'Every farmer and landowner is reviewed by your team before going live. No anonymous accounts, no unfiltered submissions.',
  },
  {
    icon: `<svg class="h-6 w-6" fill="none" stroke="currentColor" stroke-width="1.5" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" d="M3.75 6A2.25 2.25 0 0 1 6 3.75h2.25A2.25 2.25 0 0 1 10.5 6v2.25a2.25 2.25 0 0 1-2.25 2.25H6a2.25 2.25 0 0 1-2.25-2.25V6ZM3.75 15.75A2.25 2.25 0 0 1 6 13.5h2.25a2.25 2.25 0 0 1 2.25 2.25V18a2.25 2.25 0 0 1-2.25 2.25H6A2.25 2.25 0 0 1 3.75 18v-2.25ZM13.5 6a2.25 2.25 0 0 1 2.25-2.25H18A2.25 2.25 0 0 1 20.25 6v2.25A2.25 2.25 0 0 1 18 10.5h-2.25a2.25 2.25 0 0 1-2.25-2.25V6ZM13.5 15.75a2.25 2.25 0 0 1 2.25-2.25H18a2.25 2.25 0 0 1 2.25 2.25V18A2.25 2.25 0 0 1 18 20.25h-2.25A2.25 2.25 0 0 1 13.5 18v-2.25Z"/></svg>`,
    title: 'Admin control panel',
    body: 'Review queues, status management, user search, and detailed profiles — all in one dashboard built for your staff.',
  },
  {
    icon: `<svg class="h-6 w-6" fill="none" stroke="currentColor" stroke-width="1.5" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" d="M9 6.75V15m6-6v8.25m.503 3.498 4.875-2.437c.381-.19.622-.58.622-1.006V4.82c0-.836-.88-1.38-1.628-1.006l-3.869 1.934c-.317.159-.69.159-1.006 0L9.503 3.252a1.125 1.125 0 0 0-1.006 0L3.622 5.689C3.24 5.88 3 6.27 3 6.695V19.18c0 .836.88 1.38 1.628 1.006l3.869-1.934c.317-.159.69-.159 1.006 0l4.994 2.497c.317.158.69.158 1.006 0Z"/></svg>`,
    title: 'Structured listings',
    body: 'Landowners submit detailed property info — acreage, infrastructure, tenure terms, conservation status. Everything in one place for quick review.',
  },
  {
    icon: `<svg class="h-6 w-6" fill="none" stroke="currentColor" stroke-width="1.5" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" d="M8.625 12a.375.375 0 1 1-.75 0 .375.375 0 0 1 .75 0Zm0 0H8.25m4.125 0a.375.375 0 1 1-.75 0 .375.375 0 0 1 .75 0Zm0 0H12m4.125 0a.375.375 0 1 1-.75 0 .375.375 0 0 1 .75 0Zm0 0h-.375M21 12c0 4.556-4.03 8.25-9 8.25a9.764 9.764 0 0 1-2.555-.337A5.972 5.972 0 0 1 5.41 20.97a5.969 5.969 0 0 1-.474-.065 4.48 4.48 0 0 0 .978-2.025c.09-.457-.133-.901-.467-1.226C3.93 16.178 3 14.189 3 12c0-4.556 4.03-8.25 9-8.25s9 3.694 9 8.25Z"/></svg>`,
    title: 'Direct messaging',
    body: 'Farmers send inquiries directly to landowners. All conversations are threaded, admin-visible, and manageable — close, block, or intervene at any time.',
  },
  {
    icon: `<svg class="h-6 w-6" fill="none" stroke="currentColor" stroke-width="1.5" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" d="M2.036 12.322a1.012 1.012 0 0 1 0-.639C3.423 7.51 7.36 4.5 12 4.5c4.638 0 8.573 3.007 9.963 7.178.07.207.07.431 0 .639C20.577 16.49 16.64 19.5 12 19.5c-4.638 0-8.573-3.007-9.963-7.178Z"/><path stroke-linecap="round" stroke-linejoin="round" d="M15 12a3 3 0 1 1-6 0 3 3 0 0 1 6 0Z"/></svg>`,
    title: 'Public discovery',
    body: 'Approved listings appear on a public browse page — searchable by county, acreage, and tenure type. Full details unlock after sign-up.',
  },
  {
    icon: `<svg class="h-6 w-6" fill="none" stroke="currentColor" stroke-width="1.5" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" d="M9.594 3.94c.09-.542.56-.94 1.11-.94h2.593c.55 0 1.02.398 1.11.94l.213 1.281c.063.374.313.686.645.87.074.04.147.083.22.127.325.196.72.257 1.075.124l1.217-.456a1.125 1.125 0 0 1 1.37.49l1.296 2.247a1.125 1.125 0 0 1-.26 1.431l-1.003.827c-.293.241-.438.613-.43.992a7.723 7.723 0 0 1 0 .255c-.008.378.137.75.43.991l1.004.827c.424.35.534.955.26 1.43l-1.298 2.247a1.125 1.125 0 0 1-1.369.491l-1.217-.456c-.355-.133-.75-.072-1.076.124a6.47 6.47 0 0 1-.22.128c-.331.183-.581.495-.644.869l-.213 1.281c-.09.543-.56.94-1.11.94h-2.594c-.55 0-1.019-.398-1.11-.94l-.213-1.281c-.062-.374-.312-.686-.644-.87a6.52 6.52 0 0 1-.22-.127c-.325-.196-.72-.257-1.076-.124l-1.217.456a1.125 1.125 0 0 1-1.369-.49l-1.297-2.247a1.125 1.125 0 0 1 .26-1.431l1.004-.827c.292-.24.437-.613.43-.991a6.932 6.932 0 0 1 0-.255c.007-.38-.138-.751-.43-.992l-1.004-.827a1.125 1.125 0 0 1-.26-1.43l1.297-2.247a1.125 1.125 0 0 1 1.37-.491l1.216.456c.356.133.751.072 1.076-.124.072-.044.146-.086.22-.128.332-.183.582-.495.644-.869l.214-1.28Z"/><path stroke-linecap="round" stroke-linejoin="round" d="M15 12a3 3 0 1 1-6 0 3 3 0 0 1 6 0Z"/></svg>`,
    title: 'Configurable for your region',
    body: 'Crop types, livestock, tenure options, counties, and demographic fields — all configurable to match your organization\'s geography and focus.',
  },
];

const faq = [
  {
    q: 'What kind of organization is this built for?',
    a: 'Agricultural land trusts, extension services, beginning farmer programs, USDA partner organizations, and state-level ag departments. If your work involves connecting farmers to land — or land to farmers — Farmlinker is built for you.',
  },
  {
    q: 'Do we control the review and approval process?',
    a: 'Yes. Your admin team reviews every farmer and landowner profile before they go live. You set the bar, you approve or reject, and you can suspend accounts at any time. The platform gives you the tools; you make the calls.',
  },
  {
    q: 'Can we limit the platform to our specific region?',
    a: 'The county lists, crop options, and geographic scope can be configured for your region. Out of the box it covers Illinois, but the underlying field sets are adaptable.',
  },
  {
    q: 'Is this white-labeled — will it say Farmlinker?',
    a: 'White-labeling (your org\'s name, logo, and colors) is on the near-term roadmap. Current deployments run under the Farmlinker brand. Contact us to discuss what timeline looks like for your rollout.',
  },
  {
    q: 'What does it cost?',
    a: 'Pricing is based on organization size, user volume, and support tier. We don\'t publish a standard rate card because most implementations involve some configuration work. Reach out and we\'ll put together a proposal.',
  },
  {
    q: 'How long does it take to deploy?',
    a: 'A standard deployment with your data and configuration can be ready in 2–4 weeks. More complex setups — custom fields, regional option sets, branding — add time. We\'ll scope it with you before committing to a timeline.',
  },
];
---

<BaseLayout title="Platform — Farmlinker for Organizations" description="The farmland matching platform built for agricultural organizations. Vetted networks, admin controls, listings, and direct messaging — all in one place.">

  <!-- ── Nav ─────────────────────────────────────────────────────────────────── -->
  <header class="sticky top-0 z-50 border-b bg-white/95 backdrop-blur-sm">
    <div class="mx-auto flex h-14 max-w-6xl items-center justify-between px-4">
      <div class="flex items-center gap-6">
        <a href="/" class="text-lg font-bold text-primary">Farmlinker</a>
        <nav class="hidden items-center gap-1 text-sm sm:flex">
          <a href="#features" class="px-3 py-1.5 text-muted-foreground hover:text-foreground">Features</a>
          <a href="#see-it" class="px-3 py-1.5 text-muted-foreground hover:text-foreground">See it in action</a>
          <a href="#pricing" class="px-3 py-1.5 text-muted-foreground hover:text-foreground">Pricing</a>
          <a href="#faq" class="px-3 py-1.5 text-muted-foreground hover:text-foreground">FAQ</a>
        </nav>
      </div>
      <div class="flex items-center gap-2 text-sm">
        {user ? (
          <a href="/app" class="rounded-md bg-primary px-4 py-1.5 font-medium text-primary-foreground hover:bg-primary/90">Go to app</a>
        ) : (
          <>
            <a href="/auth/sign-in" class="hidden px-3 py-1.5 text-muted-foreground hover:text-foreground sm:block">Sign in</a>
            <a href="#contact" class="rounded-md bg-primary px-4 py-1.5 font-medium text-primary-foreground hover:bg-primary/90">Request a demo</a>
          </>
        )}
      </div>
    </div>
  </header>

  <!-- ── Hero ──────────────────────────────────────────────────────────────────── -->
  <section class="relative overflow-hidden bg-gradient-to-br from-zinc-900 via-zinc-800 to-zinc-900 px-4 py-24 sm:py-32 text-white">
    <div class="pointer-events-none absolute inset-0 opacity-[0.04]"
      style="background-image: radial-gradient(circle at 1px 1px, white 1px, transparent 0); background-size: 32px 32px;">
    </div>
    <div class="absolute inset-0 bg-gradient-to-br from-primary/20 via-transparent to-transparent"></div>

    <div class="relative mx-auto max-w-4xl text-center">
      <div class="mb-4 inline-block rounded-full border border-white/20 bg-white/10 px-3 py-1 text-sm font-medium text-white/80">
        Built for agricultural organizations
      </div>
      <h1 class="text-4xl font-bold tracking-tight sm:text-5xl lg:text-6xl">
        Your region.<br class="hidden sm:block" />
        Your farmers.<br class="hidden sm:block" />
        Your platform.
      </h1>
      <p class="mx-auto mt-6 max-w-2xl text-lg text-white/70 leading-relaxed">
        Farmlinker gives agricultural organizations a structured, admin-controlled platform
        to connect vetted farmers with available land — replacing spreadsheets and email
        chains with a workflow built for this work.
      </p>
      <div class="mt-10 flex flex-col items-center gap-4 sm:flex-row sm:justify-center">
        <a href="#contact"
          class="w-full rounded-xl bg-primary px-8 py-4 text-base font-semibold text-primary-foreground shadow-lg transition-all hover:bg-primary/90 sm:w-auto">
          Request a demo
        </a>
        <a href="#see-it"
          class="w-full rounded-xl border border-white/30 bg-white/10 px-8 py-4 text-base font-semibold text-white transition-all hover:bg-white/20 sm:w-auto">
          See it in action
        </a>
      </div>
      <p class="mt-5 text-sm text-white/50">
        No commitment required &nbsp;·&nbsp; Typically live in 2–4 weeks
      </p>
    </div>
  </section>

  <!-- ── Org type trust bar ─────────────────────────────────────────────────── -->
  <section class="border-b bg-white px-4 py-8">
    <div class="mx-auto max-w-5xl text-center">
      <p class="mb-6 text-xs font-semibold uppercase tracking-widest text-muted-foreground">Built for organizations like</p>
      <div class="flex flex-wrap justify-center gap-x-10 gap-y-4 text-sm font-medium text-zinc-500">
        {[
          'Agricultural Land Trusts',
          'Extension Services',
          'Beginning Farmer Programs',
          'USDA Partner Organizations',
          'State Ag Departments',
          'Conservation Districts',
        ].map(org => (
          <span class="flex items-center gap-2">
            <span class="h-1 w-1 rounded-full bg-primary/40"></span>
            {org}
          </span>
        ))}
      </div>
    </div>
  </section>

  <!-- ── Problem ────────────────────────────────────────────────────────────── -->
  <section class="bg-zinc-50 px-4 py-20">
    <div class="mx-auto max-w-5xl">
      <div class="grid items-center gap-12 lg:grid-cols-2">
        <div>
          <div class="mb-3 inline-block rounded-full bg-red-100 px-3 py-1 text-sm font-medium text-red-700">
            The problem
          </div>
          <h2 class="text-3xl font-bold">Land access is still managed with spreadsheets and phone calls.</h2>
          <p class="mt-4 text-muted-foreground leading-relaxed">
            Most agricultural organizations trying to facilitate land access are doing it manually —
            a shared Google Sheet, a waiting list managed in someone's inbox, and connections made over
            the phone with no record of what was discussed.
          </p>
          <p class="mt-4 text-muted-foreground leading-relaxed">
            It doesn't scale. It's hard to hand off. And it puts the burden on your staff instead
            of giving farmers and landowners a place to find each other.
          </p>
        </div>

        <!-- Pain point cards -->
        <div class="space-y-3">
          {[
            { label: 'No structured intake', detail: 'Farmers submit interest via email with inconsistent information.' },
            { label: 'No central record', detail: 'Landowner contact lists live in one person\'s spreadsheet.' },
            { label: 'No audit trail', detail: 'Conversations happen over email or phone — nothing documented.' },
            { label: 'Hard to scale', detail: 'One staff member\'s capacity is the ceiling for your whole program.' },
          ].map(item => (
            <div class="flex items-start gap-4 rounded-xl border border-red-100 bg-white p-4 shadow-sm">
              <div class="mt-0.5 flex h-6 w-6 shrink-0 items-center justify-center rounded-full bg-red-100">
                <svg class="h-3.5 w-3.5 text-red-500" fill="none" stroke="currentColor" stroke-width="2.5" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" d="M6 18 18 6M6 6l12 12"/></svg>
              </div>
              <div>
                <p class="text-sm font-semibold">{item.label}</p>
                <p class="text-xs text-muted-foreground">{item.detail}</p>
              </div>
            </div>
          ))}
        </div>
      </div>
    </div>
  </section>

  <!-- ── Solution bridge ────────────────────────────────────────────────────── -->
  <section class="bg-white px-4 py-16">
    <div class="mx-auto max-w-3xl text-center">
      <div class="mb-3 inline-block rounded-full bg-primary/10 px-3 py-1 text-sm font-medium text-primary">
        The solution
      </div>
      <h2 class="text-3xl font-bold">A platform purpose-built for this workflow.</h2>
      <p class="mt-4 text-lg text-muted-foreground leading-relaxed">
        Farmlinker gives your organization a structured end-to-end system — from first sign-up
        through profile review, listing approval, discovery, and the first conversation.
        Your staff stays in control. The platform does the heavy lifting.
      </p>
    </div>
  </section>

  <!-- ── Features ───────────────────────────────────────────────────────────── -->
  <section id="features" class="bg-zinc-50 px-4 py-20">
    <div class="mx-auto max-w-6xl">
      <div class="mb-12 text-center">
        <h2 class="text-3xl font-bold">Everything your program needs</h2>
        <p class="mt-3 text-muted-foreground">Six core capabilities, integrated into one workflow.</p>
      </div>

      <div class="grid gap-6 sm:grid-cols-2 lg:grid-cols-3">
        {features.map(f => (
          <div class="rounded-xl border bg-white p-6 shadow-sm">
            <div class="mb-4 flex h-11 w-11 items-center justify-center rounded-xl bg-primary/10 text-primary" set:html={f.icon} />
            <h3 class="mb-2 font-semibold">{f.title}</h3>
            <p class="text-sm leading-relaxed text-muted-foreground">{f.body}</p>
          </div>
        ))}
      </div>
    </div>
  </section>

  <!-- ── See it in action ────────────────────────────────────────────────────── -->
  <section id="see-it" class="bg-white px-4 py-24">
    <div class="mx-auto max-w-6xl">
      <div class="mb-16 text-center">
        <h2 class="text-3xl font-bold">See it in action</h2>
        <p class="mt-3 text-muted-foreground">The full workflow, from pending review to approved match.</p>
      </div>

      <!-- ── 1. Admin review queue ── -->
      <div class="mb-24 grid items-center gap-12 lg:grid-cols-2">
        <div>
          <div class="mb-3 inline-block rounded-full bg-primary/10 px-3 py-1 text-sm font-medium text-primary">Admin</div>
          <h3 class="text-2xl font-bold">Review queue — clear, fast, and actionable</h3>
          <p class="mt-4 text-muted-foreground leading-relaxed">
            Pending profiles land in a card-based review queue. Your staff sees completion percentage,
            role, and key info at a glance. Click to open the full profile in a modal — then approve
            or reject with a required reason, all without leaving the page.
          </p>
          <ul class="mt-6 space-y-2.5 text-sm">
            {[
              'Completion percentage shown on every card',
              'Full profile detail opens in a modal overlay',
              'Reject requires a reason — shown to the user',
              'Approve/reject/suspend/reactivate at any time',
            ].map(item => (
              <li class="flex items-start gap-2.5" set:html={CHECK + `<span class="text-muted-foreground">${item}</span>`} />
            ))}
          </ul>
        </div>

        <!-- Admin review mockup -->
        <div class="overflow-hidden rounded-2xl border shadow-xl">
          <!-- Browser chrome -->
          <div class="flex items-center gap-1.5 border-b bg-zinc-100 px-4 py-2.5">
            <div class="h-3 w-3 rounded-full bg-red-400"></div>
            <div class="h-3 w-3 rounded-full bg-amber-400"></div>
            <div class="h-3 w-3 rounded-full bg-green-400"></div>
            <div class="ml-3 flex-1 rounded bg-zinc-200 px-3 py-1 text-xs text-zinc-400">farmlinker.app/admin/review/users</div>
          </div>
          <!-- Content -->
          <div class="bg-zinc-50 p-4">
            <div class="mb-3 flex items-center justify-between">
              <span class="text-xs font-semibold text-zinc-700">Pending review (3)</span>
              <span class="rounded-full bg-amber-100 px-2 py-0.5 text-xs font-medium text-amber-700">3 pending</span>
            </div>
            <div class="space-y-3">
              {[
                { name: 'Sarah M.', role: 'Farmer', pct: 92, location: 'Champaign Co.' },
                { name: 'Tom R.', role: 'Landowner', pct: 78, location: 'McLean Co.' },
                { name: 'Angela K.', role: 'Farmer', pct: 85, location: 'Sangamon Co.' },
              ].map(u => (
                <div class="rounded-lg border bg-white p-3 shadow-sm">
                  <div class="flex items-start justify-between gap-2">
                    <div class="flex items-center gap-2.5">
                      <div class="flex h-8 w-8 shrink-0 items-center justify-center rounded-full bg-primary/15 text-xs font-bold text-primary">
                        {u.name.charAt(0)}
                      </div>
                      <div>
                        <p class="text-sm font-semibold leading-none">{u.name}</p>
                        <p class="mt-0.5 text-xs text-muted-foreground">{u.role} · {u.location}</p>
                      </div>
                    </div>
                    <div class="text-right">
                      <span class="text-xs font-semibold text-primary">{u.pct}%</span>
                      <p class="text-xs text-muted-foreground">complete</p>
                    </div>
                  </div>
                  <div class="mt-2.5 h-1.5 w-full overflow-hidden rounded-full bg-zinc-100">
                    <div class="h-full rounded-full bg-primary" style={`width: ${u.pct}%`}></div>
                  </div>
                  <div class="mt-2.5 flex gap-1.5">
                    <button class="flex-1 rounded bg-primary px-2 py-1 text-xs font-medium text-white">Approve</button>
                    <button class="flex-1 rounded border px-2 py-1 text-xs font-medium text-zinc-600">Review →</button>
                  </div>
                </div>
              ))}
            </div>
          </div>
        </div>
      </div>

      <!-- ── 2. Browse listings ── -->
      <div class="mb-24 grid items-center gap-12 lg:grid-cols-2">

        <!-- Listings mockup -->
        <div class="order-2 overflow-hidden rounded-2xl border shadow-xl lg:order-1">
          <div class="flex items-center gap-1.5 border-b bg-zinc-100 px-4 py-2.5">
            <div class="h-3 w-3 rounded-full bg-red-400"></div>
            <div class="h-3 w-3 rounded-full bg-amber-400"></div>
            <div class="h-3 w-3 rounded-full bg-green-400"></div>
            <div class="ml-3 flex-1 rounded bg-zinc-200 px-3 py-1 text-xs text-zinc-400">farmlinker.app/browse</div>
          </div>
          <div class="bg-zinc-50 p-4">
            <!-- Filter bar -->
            <div class="mb-3 flex gap-2 rounded-lg border bg-white p-2 text-xs shadow-sm">
              <div class="rounded border bg-zinc-50 px-2 py-1 text-zinc-500">All counties</div>
              <div class="rounded border bg-zinc-50 px-2 py-1 text-zinc-500">Acreage</div>
              <div class="rounded border bg-zinc-50 px-2 py-1 text-zinc-500">Tenure</div>
              <div class="ml-auto rounded bg-primary px-2 py-1 font-medium text-white">Apply</div>
            </div>
            <!-- Listing cards -->
            <div class="grid grid-cols-2 gap-2.5">
              {[
                { name: 'Rolling Hills Farm', county: 'McLean', acres: 240, tenure: 'Cash rent' },
                { name: 'Sunrise Acres', county: 'Sangamon', acres: 180, tenure: 'Share crop' },
                { name: 'Prairie View', county: 'Champaign', acres: 320, tenure: 'Cash rent' },
                { name: 'Riverbend Farm', county: 'Peoria', acres: 95, tenure: 'Flexible' },
              ].map(l => (
                <div class="overflow-hidden rounded-lg border bg-white shadow-sm">
                  <div class="flex aspect-video items-center justify-center bg-gradient-to-br from-primary/10 to-primary/5">
                    <svg viewBox="0 0 40 28" class="h-8 w-8 text-primary/30" fill="currentColor">
                      <circle cx="31" cy="7" r="5" opacity="0.5"/>
                      <ellipse cx="36" cy="24" rx="22" ry="9" opacity="0.2"/>
                      <ellipse cx="8" cy="26" rx="16" ry="7" opacity="0.35"/>
                    </svg>
                  </div>
                  <div class="p-2">
                    <p class="text-xs font-semibold leading-tight">{l.name}</p>
                    <p class="text-xs text-muted-foreground">{l.county} Co. · {l.acres} ac</p>
                    <span class="mt-1 inline-block rounded-full bg-primary/10 px-1.5 py-0.5 text-xs text-primary">{l.tenure}</span>
                  </div>
                </div>
              ))}
            </div>
          </div>
        </div>

        <div class="order-1 lg:order-2">
          <div class="mb-3 inline-block rounded-full bg-primary/10 px-3 py-1 text-sm font-medium text-primary">Discovery</div>
          <h3 class="text-2xl font-bold">Farmers find land — no staff mediation required</h3>
          <p class="mt-4 text-muted-foreground leading-relaxed">
            Approved listings appear in a searchable, filterable grid. Farmers can explore
            by county, acreage range, tenure type, and organic eligibility — without a
            phone call or staff member in the loop.
          </p>
          <ul class="mt-6 space-y-2.5 text-sm">
            {[
              'Public browse page requires no sign-in for basic info',
              'Full details and contact gated to approved accounts',
              'Filter by county, acreage, tenure, and organic status',
              'Photo gallery with signed, expiring storage URLs',
            ].map(item => (
              <li class="flex items-start gap-2.5" set:html={CHECK + `<span class="text-muted-foreground">${item}</span>`} />
            ))}
          </ul>
        </div>
      </div>

      <!-- ── 3. Inquiry / messaging ── -->
      <div class="grid items-center gap-12 lg:grid-cols-2">
        <div>
          <div class="mb-3 inline-block rounded-full bg-primary/10 px-3 py-1 text-sm font-medium text-primary">Messaging</div>
          <h3 class="text-2xl font-bold">Direct conversations, fully visible to admins</h3>
          <p class="mt-4 text-muted-foreground leading-relaxed">
            Farmers send inquiries directly to landowners. Both parties see a threaded message view.
            Admins can read every thread, send messages, and block conversations if needed —
            keeping oversight without being in the way.
          </p>
          <ul class="mt-6 space-y-2.5 text-sm">
            {[
              'Farmers initiate; landowners respond at their own pace',
              'Full thread history on both sides',
              'Admin visibility into all conversations',
              'Inquiry status: open, closed, or blocked',
            ].map(item => (
              <li class="flex items-start gap-2.5" set:html={CHECK + `<span class="text-muted-foreground">${item}</span>`} />
            ))}
          </ul>
        </div>

        <!-- Messaging mockup -->
        <div class="overflow-hidden rounded-2xl border shadow-xl">
          <div class="flex items-center gap-1.5 border-b bg-zinc-100 px-4 py-2.5">
            <div class="h-3 w-3 rounded-full bg-red-400"></div>
            <div class="h-3 w-3 rounded-full bg-amber-400"></div>
            <div class="h-3 w-3 rounded-full bg-green-400"></div>
            <div class="ml-3 flex-1 rounded bg-zinc-200 px-3 py-1 text-xs text-zinc-400">farmlinker.app/app/inquiries/…</div>
          </div>
          <div class="bg-white p-4">
            <div class="mb-3 border-b pb-3">
              <p class="text-xs font-semibold text-zinc-700">Rolling Hills Farm · McLean Co.</p>
              <span class="rounded-full bg-green-100 px-2 py-0.5 text-xs text-green-700">Open</span>
            </div>
            <div class="space-y-3">
              <!-- Farmer message -->
              <div class="flex gap-2">
                <div class="mt-0.5 h-6 w-6 shrink-0 rounded-full bg-primary/20 text-center text-xs font-bold leading-6 text-primary">J</div>
                <div class="flex-1 rounded-lg rounded-tl-none bg-zinc-50 p-2.5 text-xs">
                  <p class="mb-1 font-medium">Jake W. <span class="font-normal text-muted-foreground">· Farmer</span></p>
                  <p class="text-muted-foreground">Hi, I'm an experienced grain farmer looking to expand in McLean County. I've farmed 300 acres for 10 years and I'm very interested in a long-term cash rent arrangement…</p>
                </div>
              </div>
              <!-- Landowner reply -->
              <div class="flex flex-row-reverse gap-2">
                <div class="mt-0.5 h-6 w-6 shrink-0 rounded-full bg-zinc-200 text-center text-xs font-bold leading-6 text-zinc-600">R</div>
                <div class="flex-1 rounded-lg rounded-tr-none bg-primary/5 p-2.5 text-xs">
                  <p class="mb-1 font-medium">R. Thompson <span class="font-normal text-muted-foreground">· Landowner</span></p>
                  <p class="text-muted-foreground">Thanks Jake — your experience sounds like a great fit. Would you be open to a conversation about conservation practices? That's important to me…</p>
                </div>
              </div>
            </div>
            <!-- Reply box -->
            <div class="mt-3 flex gap-2 rounded-lg border bg-zinc-50 px-3 py-2 text-xs text-muted-foreground">
              <span class="flex-1">Write a message…</span>
              <button class="rounded bg-primary px-2 py-0.5 text-white">Send</button>
            </div>
          </div>
        </div>
      </div>
    </div>
  </section>

  <!-- ── Built for your org ─────────────────────────────────────────────────── -->
  <section class="bg-zinc-900 px-4 py-20 text-white">
    <div class="mx-auto max-w-5xl">
      <div class="mb-12 text-center">
        <h2 class="text-3xl font-bold">Built to run as your platform</h2>
        <p class="mt-3 text-white/60">You're not getting a SaaS product with your logo on it. You're getting a configurable system that works the way your program works.</p>
      </div>

      <div class="grid gap-6 sm:grid-cols-2 lg:grid-cols-3">
        {[
          {
            title: 'Your admin team, your process',
            body: 'Your staff controls the review queue. You set approval criteria, write rejection reasons, and manage user status — the platform enforces your decisions.',
          },
          {
            title: 'Your geographic scope',
            body: 'County lists, regions, and location fields are scoped to where your program operates. Not a national directory — your footprint.',
          },
          {
            title: 'Your field sets',
            body: 'Crop types, tenure options, livestock categories, infrastructure options — all configurable to match your region\'s ag landscape and terminology.',
          },
          {
            title: 'Your data',
            body: 'Profiles, listings, and conversations live in your Supabase instance. You own the database, the storage, and the export — no lock-in.',
          },
          {
            title: 'White-label ready',
            body: 'Your organization\'s name, brand colors, and logo. White-labeling is on the near-term roadmap — ask about current status when you reach out.',
          },
          {
            title: 'Extensible by design',
            body: 'Built on Astro + Supabase with clear data models and a migration-based schema. New fields, new workflows, and integrations are all on the table.',
          },
        ].map(item => (
          <div class="rounded-xl border border-white/10 bg-white/5 p-5">
            <h3 class="mb-2 font-semibold text-white">{item.title}</h3>
            <p class="text-sm leading-relaxed text-white/60">{item.body}</p>
          </div>
        ))}
      </div>
    </div>
  </section>

  <!-- ── Pricing ────────────────────────────────────────────────────────────── -->
  <section id="pricing" class="bg-white px-4 py-20">
    <div class="mx-auto max-w-4xl text-center">
      <h2 class="text-3xl font-bold">Pricing that fits your program</h2>
      <p class="mt-4 text-muted-foreground leading-relaxed max-w-xl mx-auto">
        We don't publish a standard rate card. Implementations vary by size, configuration,
        support tier, and whether you need regional customization. Reach out and we'll put
        together a proposal specific to your organization.
      </p>

      <div class="mt-12 grid gap-6 sm:grid-cols-3">
        {[
          {
            tier: 'Standard',
            desc: 'Core platform with your data and region. Ideal for smaller programs just getting started.',
            items: ['Full admin panel', 'Farmer + landowner flows', 'Browse + inquiries', 'Email support'],
          },
          {
            tier: 'Professional',
            desc: 'Everything in Standard plus configuration, branding, and priority support.',
            items: ['Custom field sets', 'White-label branding', 'Onboarding assistance', 'Priority support'],
            highlight: true,
          },
          {
            tier: 'Enterprise',
            desc: 'Custom development, integrations, and an SLA for larger or multi-region programs.',
            items: ['Multi-region support', 'Custom integrations', 'Dedicated SLA', 'Dedicated implementation'],
          },
        ].map(tier => (
          <div class:list={[
            'rounded-xl border p-6 text-left shadow-sm',
            tier.highlight ? 'border-primary bg-primary/5 ring-1 ring-primary' : 'bg-white',
          ]}>
            {tier.highlight && (
              <div class="mb-3 inline-block rounded-full bg-primary px-2.5 py-0.5 text-xs font-medium text-white">Most common</div>
            )}
            <h3 class="text-lg font-bold">{tier.tier}</h3>
            <p class="mt-2 text-sm text-muted-foreground">{tier.desc}</p>
            <ul class="mt-5 space-y-2">
              {tier.items.map(item => (
                <li class="flex items-center gap-2 text-sm" set:html={CHECK + `<span>${item}</span>`} />
              ))}
            </ul>
            <a href="#contact"
              class:list={[
                'mt-6 block w-full rounded-lg px-4 py-2.5 text-center text-sm font-semibold transition-colors',
                tier.highlight
                  ? 'bg-primary text-primary-foreground hover:bg-primary/90'
                  : 'border border-primary text-primary hover:bg-primary/5',
              ]}>
              Get a quote
            </a>
          </div>
        ))}
      </div>
    </div>
  </section>

  <!-- ── FAQ ────────────────────────────────────────────────────────────────── -->
  <section id="faq" class="bg-zinc-50 px-4 py-20">
    <div class="mx-auto max-w-3xl">
      <div class="mb-12 text-center">
        <h2 class="text-3xl font-bold">Frequently asked questions</h2>
      </div>
      <div class="space-y-4">
        {faq.map(item => (
          <details class="group rounded-xl border bg-white shadow-sm">
            <summary class="flex cursor-pointer items-center justify-between gap-4 p-5 font-semibold">
              <span>{item.q}</span>
              <svg xmlns="http://www.w3.org/2000/svg" width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" class="shrink-0 transition-transform group-open:rotate-180" aria-hidden="true"><path d="m6 9 6 6 6-6"/></svg>
            </summary>
            <div class="border-t px-5 pb-5 pt-4 text-sm leading-relaxed text-muted-foreground">
              {item.a}
            </div>
          </details>
        ))}
      </div>
    </div>
  </section>

  <!-- ── Contact / CTA ─────────────────────────────────────────────────────── -->
  <section id="contact" class="bg-white px-4 py-20">
    <div class="mx-auto max-w-2xl">
      <div class="mb-10 text-center">
        <h2 class="text-3xl font-bold">Ready to see it with your data?</h2>
        <p class="mt-3 text-muted-foreground">
          We'll walk you through the platform, answer your questions, and put together a
          proposal. No commitment required.
        </p>
      </div>

      <form
        name="platform-demo-request"
        method="POST"
        action="/platform/thank-you"
        class="space-y-5 rounded-2xl border bg-white p-8 shadow-sm"
        data-netlify="true"
      >
        <input type="hidden" name="form-name" value="platform-demo-request" />

        <div class="grid gap-4 sm:grid-cols-2">
          <div class="space-y-1.5">
            <label class="text-sm font-medium" for="c-first">First name</label>
            <input id="c-first" name="first_name" type="text" required
              class="w-full rounded-lg border px-3 py-2 text-sm focus:outline-none focus:ring-2 focus:ring-primary" />
          </div>
          <div class="space-y-1.5">
            <label class="text-sm font-medium" for="c-last">Last name</label>
            <input id="c-last" name="last_name" type="text" required
              class="w-full rounded-lg border px-3 py-2 text-sm focus:outline-none focus:ring-2 focus:ring-primary" />
          </div>
        </div>

        <div class="space-y-1.5">
          <label class="text-sm font-medium" for="c-email">Work email</label>
          <input id="c-email" name="email" type="email" required
            class="w-full rounded-lg border px-3 py-2 text-sm focus:outline-none focus:ring-2 focus:ring-primary" />
        </div>

        <div class="space-y-1.5">
          <label class="text-sm font-medium" for="c-org">Organization name</label>
          <input id="c-org" name="organization" type="text" required
            class="w-full rounded-lg border px-3 py-2 text-sm focus:outline-none focus:ring-2 focus:ring-primary" />
        </div>

        <div class="space-y-1.5">
          <label class="text-sm font-medium" for="c-type">Organization type</label>
          <select id="c-type" name="org_type"
            class="w-full rounded-lg border px-3 py-2 text-sm focus:outline-none focus:ring-2 focus:ring-primary">
            <option value="">Select one…</option>
            <option>Agricultural Land Trust</option>
            <option>Extension Service</option>
            <option>Beginning Farmer Program</option>
            <option>USDA Partner Organization</option>
            <option>State Agricultural Department</option>
            <option>Conservation District</option>
            <option>Other</option>
          </select>
        </div>

        <div class="space-y-1.5">
          <label class="text-sm font-medium" for="c-msg">Anything you'd like us to know? <span class="font-normal text-muted-foreground">(optional)</span></label>
          <textarea id="c-msg" name="message" rows={3}
            placeholder="Region you operate in, approximate number of farmers/landowners in your network, timeline…"
            class="w-full rounded-lg border px-3 py-2 text-sm focus:outline-none focus:ring-2 focus:ring-primary resize-none"
          ></textarea>
        </div>

        <button type="submit"
          class="w-full rounded-xl bg-primary py-3 text-sm font-semibold text-primary-foreground hover:bg-primary/90 transition-colors">
          Request a demo
        </button>

        <p class="text-center text-xs text-muted-foreground">
          We'll follow up within one business day.
        </p>
      </form>
    </div>
  </section>

  <!-- ── Footer ─────────────────────────────────────────────────────────────── -->
  <footer class="border-t bg-zinc-900 px-4 py-10 text-white">
    <div class="mx-auto max-w-6xl">
      <div class="flex flex-col gap-6 sm:flex-row sm:items-center sm:justify-between">
        <div>
          <a href="/" class="text-lg font-bold text-white">Farmlinker</a>
          <p class="mt-1 text-sm text-white/40">Connecting farmers with land.</p>
        </div>
        <nav class="flex flex-wrap gap-x-6 gap-y-2 text-sm text-white/50">
          <a href="/" class="hover:text-white">For farmers & landowners</a>
          <a href="/browse" class="hover:text-white">Browse listings</a>
          <a href="#faq" class="hover:text-white">FAQ</a>
          <a href="#contact" class="hover:text-white">Contact</a>
        </nav>
      </div>
      <div class="mt-8 border-t border-white/10 pt-6 text-xs text-white/30">
        © {new Date().getFullYear()} Farmlinker. All rights reserved.
      </div>
    </div>
  </footer>

</BaseLayout>
