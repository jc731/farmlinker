---
import AdminLayout from '@/layouts/AdminLayout.astro';

const { supabase } = Astro.locals;

const { data: pending } = await supabase
  .from('profiles')
  .select('id, email, roles, status, first_name, last_name, phone, created_at')
  .eq('status', 'pending')
  .order('created_at', { ascending: true });

const fmt = (iso: string) => new Date(iso).toLocaleDateString('en-US', {
  month: 'short', day: 'numeric', year: 'numeric',
});
---

<AdminLayout title="Pending users">
  <div class="space-y-6">
    <div class="flex items-center justify-between">
      <div>
        <h1 class="text-2xl font-bold">Pending users</h1>
        <p class="text-sm text-muted-foreground">{pending?.length ?? 0} awaiting review</p>
      </div>
      <a href="/admin/users" class="text-sm text-primary hover:underline">View all users →</a>
    </div>

    {(!pending || pending.length === 0) && (
      <div class="rounded-lg border bg-white p-12 text-center text-muted-foreground shadow-sm">
        No pending users — you're all caught up.
      </div>
    )}

    {pending && pending.length > 0 && (
      <div class="overflow-x-auto rounded-lg border bg-white shadow-sm">
        <table class="w-full text-sm">
          <thead class="border-b bg-muted/40 text-xs font-medium uppercase tracking-wide text-muted-foreground">
            <tr>
              <th class="px-4 py-3 text-left">Name</th>
              <th class="px-4 py-3 text-left">Email</th>
              <th class="px-4 py-3 text-left">Role(s)</th>
              <th class="px-4 py-3 text-left">Joined</th>
              <th class="px-4 py-3 text-left">Actions</th>
            </tr>
          </thead>
          <tbody class="divide-y">
            {pending.map(user => (
              <tr class="hover:bg-muted/20">
                <td class="px-4 py-3 font-medium">
                  <a href={`/admin/users/${user.id}`} class="hover:text-primary hover:underline">
                    {user.first_name} {user.last_name}
                  </a>
                </td>
                <td class="px-4 py-3 text-muted-foreground">{user.email}</td>
                <td class="px-4 py-3">
                  <div class="flex flex-wrap gap-1">
                    {user.roles.map((r: string) => (
                      <span class="rounded-full bg-primary/10 px-2 py-0.5 text-xs font-medium capitalize text-primary">
                        {r}
                      </span>
                    ))}
                  </div>
                </td>
                <td class="px-4 py-3 text-muted-foreground">{fmt(user.created_at)}</td>
                <td class="px-4 py-3">
                  <div class="flex gap-2">
                    <form method="POST" action={`/api/admin/users/${user.id}/approve`}>
                      <button type="submit"
                        class="rounded bg-primary px-3 py-1 text-xs font-medium text-primary-foreground hover:bg-primary/90">
                        Approve
                      </button>
                    </form>
                    <form method="POST" action={`/api/admin/users/${user.id}/reject`}>
                      <button type="submit"
                        class="rounded border border-destructive px-3 py-1 text-xs font-medium text-destructive hover:bg-destructive/10">
                        Reject
                      </button>
                    </form>
                    <a href={`/admin/users/${user.id}`}
                      class="rounded border px-3 py-1 text-xs font-medium hover:bg-muted">
                      View
                    </a>
                  </div>
                </td>
              </tr>
            ))}
          </tbody>
        </table>
      </div>
    )}
  </div>
</AdminLayout>
