---
import AdminLayout from '@/layouts/AdminLayout.astro';
import { createSupabaseAdminClient } from '@/lib/supabase/admin';
import DataTable from '@/components/DataTable.astro';
import Th from '@/components/Th.astro';
import Tr from '@/components/Tr.astro';
import Td from '@/components/Td.astro';
import EmptyState from '@/components/EmptyState.astro';
import PageHeader from '@/components/PageHeader.astro';
import { fmtDate } from '@/lib/format';

const { profile } = Astro.locals;
if (!profile?.roles.includes('admin')) return Astro.redirect('/app');

const admin = createSupabaseAdminClient();

const { data: inquiries } = await admin
  .from('inquiries')
  .select(`
    id, status, created_at,
    listings ( id, property_name, county, state ),
    from_profile:profiles!inquiries_from_profile_id_fkey ( id, first_name, last_name ),
    to_profile:profiles!inquiries_to_profile_id_fkey   ( id, first_name, last_name )
  `)
  .order('created_at', { ascending: false });

const STATUS_STYLE: Record<string, string> = {
  open:    'bg-green-100 text-green-700',
  closed:  'bg-zinc-100 text-zinc-500',
  blocked: 'bg-red-100 text-red-600',
};

const counts = {
  open:    (inquiries ?? []).filter(i => i.status === 'open').length,
  closed:  (inquiries ?? []).filter(i => i.status === 'closed').length,
  blocked: (inquiries ?? []).filter(i => i.status === 'blocked').length,
};
---

<AdminLayout title="Inquiries">
  <div class="space-y-6">
    <PageHeader title="All inquiries">
      <div slot="action" class="flex gap-3 text-sm text-muted-foreground">
        <span>{counts.open} open</span>
        <span>{counts.closed} closed</span>
        {counts.blocked > 0 && <span class="text-red-600">{counts.blocked} blocked</span>}
      </div>
    </PageHeader>

    {!inquiries?.length ? (
      <EmptyState message="No inquiries yet." />
    ) : (
      <DataTable>
        <tr slot="head">
          <Th>Listing</Th>
          <Th>Farmer</Th>
          <Th>Landowner</Th>
          <Th>Status</Th>
          <Th>Started</Th>
          <Th></Th>
        </tr>
        {(inquiries ?? []).map(inq => {
          const listing     = inq.listings     as unknown as { id: string; property_name: string | null; county: string | null; state: string | null } | null;
          const fromProfile = inq.from_profile as unknown as { id: string; first_name: string; last_name: string } | null;
          const toProfile   = inq.to_profile   as unknown as { id: string; first_name: string; last_name: string } | null;
          return (
            <Tr>
              <Td class="font-medium">
                {listing?.property_name ?? '—'}
                {listing?.county && <div class="text-xs font-normal text-muted-foreground">{listing.county} County, {listing.state}</div>}
              </Td>
              <Td>
                {fromProfile
                  ? <a href={`/admin/users/${fromProfile.id}`} class="text-primary hover:underline">{fromProfile.first_name} {fromProfile.last_name}</a>
                  : '—'}
              </Td>
              <Td>
                {toProfile
                  ? <a href={`/admin/users/${toProfile.id}`} class="text-primary hover:underline">{toProfile.first_name} {toProfile.last_name}</a>
                  : '—'}
              </Td>
              <Td>
                <span class:list={['rounded-full px-2.5 py-0.5 text-xs font-medium capitalize', STATUS_STYLE[inq.status] ?? '']}>
                  {inq.status}
                </span>
              </Td>
              <Td class="text-muted-foreground">{fmtDate(inq.created_at)}</Td>
              <Td class="text-right">
                <a href={`/admin/inquiries/${inq.id}`} class="text-primary hover:underline">View →</a>
              </Td>
            </Tr>
          );
        })}
      </DataTable>
    )}
  </div>
</AdminLayout>
