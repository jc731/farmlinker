---
// Public during development — move to /app/onboarding/farmer and wire auth when ready
import AuthLayout from '@/layouts/AuthLayout.astro';
import { Card, CardContent, CardHeader, CardTitle, CardDescription } from '@/components/ui/card';
import { FarmerProfileForm } from '@/components/onboarding/FarmerProfileForm';
---

<AuthLayout title="Farmer Profile">
  <Card>
    <CardHeader>
      <CardTitle>Farmer profile</CardTitle>
      <CardDescription>
        Complete your profile so we can match you with the right land and landowners.
      </CardDescription>
    </CardHeader>
    <CardContent>
      <FarmerProfileForm client:load />
    </CardContent>
  </Card>
</AuthLayout>
